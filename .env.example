# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
APP_NAME=ExplainableMed API
APP_VERSION=1.0.0
DEBUG=false

# ─────────────────────────────────────────────
# CORS — tell backend which frontend URLs to allow
# Add your frontend dev's local URL here
# In production, replace with your deployed domain
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]

# ─────────────────────────────────────────────
# MODEL WEIGHTS
# Path where Dev 1's .pth files are dropped
# Relative to backend/ directory
# ─────────────────────────────────────────────
MODEL_WEIGHTS_DIR=model_weights

# ─────────────────────────────────────────────
# SHAP BACKGROUND SAMPLES (optional)
# If Dev 1 saves background tensors, put them here
# If folder is empty → Integrated Gradients is used automatically
# ─────────────────────────────────────────────
BACKGROUND_SAMPLES_DIR=background_samples

# ─────────────────────────────────────────────
# GROQ API — FREE TIER
# Get key at: https://console.groq.com
# Free limit: 30 req/min on llama-3.3-70b-versatile
# ─────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
# INFERENCE
# Minimum confidence to trust a prediction
# ─────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.6
